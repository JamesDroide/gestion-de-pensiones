{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "sh -c 'python -m src.infrastructure.database.seed && uvicorn src.main:app --host 0.0.0.0 --port $PORT'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}